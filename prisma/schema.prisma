generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Sistemi yönetecek, onay verecek ve operatörlük yapacak Adminler
model Admin {
  id         Int      @id @default(autoincrement())
  telegramId String   @unique
  name       String   
  createdAt  DateTime @default(now())
}

// Müşteriler (Mağazalar)
model Store {
  id          Int      @id @default(autoincrement())
  telegramId  String   @unique
  phone       String
  name        String   
  storeName   String?  
  address     String?  
  
  isApproved  Boolean  @default(false)
  orders      Order[]
}

// Ürün Kategorileri
model Category {
  id       Int       @id @default(autoincrement())
  name     String    
  products Product[]
}

// Ürünler
model Product {
  id          Int         @id @default(autoincrement())
  name        String      
  price       Float
  isAvailable Boolean     @default(true)
  
  // Ürünü kategoriye bağlıyoruz
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  
  orderItems  OrderItem[]
}

// Siparişler
model Order {
  id        Int         @id @default(autoincrement())
  storeId   Int
  store     Store       @relation(fields: [storeId], references: [id])
  status    String      @default("ОЧІКУЄ") // OCIKUE (Bekliyor)
  total     Float
  items     OrderItem[]
  createdAt DateTime    @default(now())
}

// Sipariş Detayları
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
}